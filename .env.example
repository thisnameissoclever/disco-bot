# =========================================================
# Disco Stew - environment configuration
# Copy to .env (local) or set in Render service settings.
# =========================================================

# --- Discord ---
# From https://discord.com/developers/applications -> Bot -> Token
DISCORD_TOKEN=
# Application (client) id - shown on the General Information page
DISCORD_CLIENT_ID=
# Optional. If set, slash commands also register to this guild for fast iteration during development.
DISCORD_DEV_GUILD_ID=
# Optional. A Discord user id who bypasses per-guild admin checks (super-admin during bootstrapping).
OWNER_DISCORD_ID=

# --- Database ---
# Render injects this automatically when you connect a Render Postgres instance.
DATABASE_URL=postgres://user:password@localhost:5432/disco_stew

# --- OpenAI ---
OPENAI_API_KEY=
# Vector store id created via `npm run upload-knowledge servicenow-development`.
# Used as a default when no per-guild assistant override is set.
SERVICENOW_VECTOR_STORE_ID=

# --- Future providers (leave blank unless you wire them up) ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
